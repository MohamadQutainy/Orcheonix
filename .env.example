# OpenAI API
# Required for live LLM calls.
OPENAI_API_KEY=your_openai_api_key_here

# Optional override. Leave empty for the official OpenAI API.
# OPENAI_BASE_URL=

# Default model. Change this if your account exposes a different exact model id.
MODEL_NAME=gpt-5.4-nano

# External research tools
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# Runtime tuning
MAX_RETRIES=1
MIN_RESULT_LEN=200
